# Sauvegardes exportées par l'application (contiennent tes vraies
# transactions, soldes et libellés bancaires). NE PAS versionner.
mon-budget-*.json
*sauvegarde*.json
*backup*.json

# Extraits de compte bruts (PDF / CSV / XLSX) — données sensibles
*.pdf
*.csv
*.xls
*.xlsx
*.tsv
extraits/
releves/
data/

# Fichiers système / éditeur
.DS_Store
Thumbs.db
*.swp
*~
.vscode/
.idea/

# Dépendances éventuelles (si un jour build local)
node_modules/
